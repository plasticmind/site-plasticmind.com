---
pagination:
  data: collections.tagList
  size: 1
  alias: tag
eleventyExcludeFromCollections: true
permalink: /tags/{{ tag.slug }}/
---

{% extends "layouts/base.njk" %}

{% block content %}

{# Get tag metadata from data file if it exists #}
{% set tagMeta = tagDescriptions[tag.slug] %}

{# Filter posts that have this tag #}
{% set taggedPosts = [] %}
{% for post in collections.posts %}
  {% if post.data.tags and tag.name in post.data.tags %}
    {% set taggedPosts = (taggedPosts.push(post), taggedPosts) %}
  {% endif %}
{% endfor %}

{# Group posts by year #}
{% set yearGroups = taggedPosts | groupByYear %}

<section class="c-section">
  <div class="l-container--lg">
    <header class="c-archive-header">
      <h1 class="c-archive-header__title">{{ tag.name }}</h1>
      {% if tagMeta and tagMeta.description %}
        <p class="c-archive-header__description">{{ tagMeta.description }}</p>
      {% endif %}
      <p class="c-archive-header__count">{{ taggedPosts.length }} post{% if taggedPosts.length != 1 %}s{% endif %}</p>
    </header>

    {% if yearGroups.length %}
    <div class="c-year-timeline">
      {% for group in yearGroups %}
        <div class="c-year-timeline__group">
          <div class="c-year-timeline__bar"></div>
          <div class="c-year-timeline__content">
            <h2 class="c-year-timeline__year">{{ group.year }}</h2>
            <ul class="c-year-timeline__posts">
              {% for post in group.posts %}
                <li class="c-year-timeline__item">
                  <time class="c-year-timeline__date">{{ post.date | dateShort }}</time>
                  <div class="c-year-timeline__details">
                    <a href="{{ post.url }}" class="c-year-timeline__link">{{ post.data.title }}</a>
                    {% if post.data.subtitle %}
                      <span class="c-year-timeline__subtitle">{{ post.data.subtitle }}</span>
                    {% endif %}
                  </div>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endfor %}
    </div>
    {% else %}
    <p>No posts found with this tag.</p>
    {% endif %}
  </div>
</section>

{% endblock %}
