{% extends "layouts/base.njk" %}

{% block content %}

<article class="c-article c-article--home">
  <div class="l-container--lg">

    <div class="c-bio">
      <img src="/assets/i/jesse-gardner.jpg" alt="Jesse Gardner" class="c-bio__photo">
      <div class="c-bio__text">
        <h1 class="c-heading c-heading--lg">Hi, I'm Jesse!</h1>
        <p class="c-subtitle">I care a lot about empowering people with technology.</p>
      </div>
    </div>

    <div class="c-article__body">
      <p>I've spent 25 years at the intersection of design and engineering. I currently direct the Accessibility and Design Systems teams for <a href="https://designsystem.ny.gov">New York State</a>, where I'm exploring how design systems can serve as AI infrastructure. I also write about bridging design and engineering at <a href="https://practicaldesignsystems.com">Practical Design Systems</a>.</p>
    </div>

    {% include "partials/end-mark.njk" %}

  </div>
</article>

<section class="c-section">
  <div class="l-container--lg">
    <h2 class="c-heading c-heading--md">Selected Articles</h2>
    <ul class="c-selected-articles">
      {% for article in selectedArticles %}
        <li class="c-selected-articles__item">
          <a href="{{ article.url }}" class="c-selected-articles__link"{% if article.url.startsWith('http') %} rel="external"{% endif %}>
            <span class="c-selected-articles__title">{{ article.title }}</span>
            <span class="c-selected-articles__meta">
              <span class="c-selected-articles__publication">{{ article.publication }}</span>
              <span class="c-selected-articles__year">{{ article.year }}</span>
            </span>
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="c-section">
  <div class="l-container--lg">
    <h2 class="c-heading c-heading--md">Press & Mentions</h2>
    <ul class="c-press-mentions">
      {% for item in pressMentions %}
        <li class="c-press-mentions__item">
          <a href="{{ item.url }}" class="c-press-mentions__link" rel="external">
            <span class="c-press-mentions__title">{{ item.title }}</span>
            <span class="c-press-mentions__meta">
              <span class="c-press-mentions__venue">{{ item.venue }}</span>
              <span class="c-press-mentions__type">{{ item.type }}</span>
              <span class="c-press-mentions__year">{{ item.year }}</span>
            </span>
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>

