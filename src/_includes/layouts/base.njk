<!DOCTYPE html>
<html lang="en">
  <head>
    {% include "partials/head-meta.njk" %}
    {% if crawl == 'false' %}
    <meta name="robots" content="noindex">
    {% endif %}
    {% block styles %}{% endblock %}
  </head>
  <body class="{% if section  %}l--{{ section }}{% else %}l--home{% endif %}">
    <a href="#main-content" class="u-skip-link">Skip to main content</a>
    <div class="l-shell" data-drawer="">

      {% include "partials/drawer-left.njk" %}

      <div class="l-drawer-overlay" aria-hidden="true"></div>

      <button class="c-edge-handle c-edge-handle--left" hidden
              aria-label="Open navigation menu"
              aria-expanded="false"
              data-edge-handle="left">
        <span class="c-edge-handle__indicator">
          <span class="c-edge-handle__line"></span>
          <span class="c-edge-handle__label">Menu</span>
        </span>
      </button>

      {% include "partials/site-header.njk" %}

      <main id="main-content" class="l-main">
        {% include "partials/archive-banner.njk" %}

        {# If featureImage is set but not post #}
        {% if featureImage and not page.inputPath.includes('/content/posts/') %}
          <div class="c-feature-image">
            <img src="{{ featureImage }}" alt="{{ alt_text if alt_text else title | safe }}">
          </div>
        {% endif %}
        {% block content %}
        {{ content | safe }}
        {% endblock %}
      </main>

      <button class="c-edge-handle c-edge-handle--right" hidden
              aria-label="Open post details"
              aria-expanded="false"
              data-edge-handle="right">
        <span class="c-edge-handle__indicator">
          <span class="c-edge-handle__line"></span>
          <span class="c-edge-handle__label">Info</span>
        </span>
      </button>

      {% include "partials/drawer-right.njk" %}

      {# Swipe hint for first-time touch users #}
      <div class="c-swipe-hint" hidden aria-hidden="true">
        <div class="c-swipe-hint__item c-swipe-hint__item--left" data-swipe-hint="left">
          <div class="c-swipe-hint__graphic">
            <span class="c-swipe-hint__circle"></span>
            <span class="c-swipe-hint__trail"></span>
          </div>
          <span class="c-swipe-hint__label">Swipe for menu</span>
        </div>
      </div>

      {% include "partials/site-footer.njk" %}

    </div>
  </body>

  {% include "partials/site-js-global.njk" %}
  {% block scripts %}{% endblock %}
</html>
