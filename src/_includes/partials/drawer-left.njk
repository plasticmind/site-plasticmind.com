{# Drawer: Left - Hidden by default, revealed on swipe or menu button click #}

<aside id="menu-drawer" class="l-drawer l-drawer--left" inert>
  {# Gradient Toolbar Bar #}
  <div class="c-toolbar">
    {# Logo at top #}
    <div class="c-toolbar__logo">
      <a href="/" title="Home">
        {% include "svg/logo-mark-color.svg" %}
      </a>
    </div>

    {# Option buttons at bottom - these toggle bottom drawers #}
    <ul class="c-toolbar__list">
      <li><button class="c-button" aria-label="About me" data-drawer-target="info-drawer">{% include "svg/icon-info.svg" %}</button></li>
      <li><button class="c-button" aria-label="Text settings" data-drawer-target="text-drawer">{% include "svg/icon-text.svg" %}</button></li>
      <li><button class="c-button" aria-label="Search" data-drawer-target="search-drawer">{% include "svg/icon-search.svg" %}</button></li>
      <li><button class="c-button c-theme-toggle" aria-label="Toggle color mode" data-action="toggle-theme">
        <svg class="c-theme-toggle__icon c-theme-toggle__icon--light" width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.05 3.05l1.06 1.06M11.89 11.89l1.06 1.06M3.05 12.95l1.06-1.06M11.89 4.11l1.06-1.06" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <svg class="c-theme-toggle__icon c-theme-toggle__icon--system" width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 1.5A6.5 6.5 0 0 1 8 14.5Z" fill="currentColor"/>
          <path d="M8 5.5A2.5 2.5 0 0 1 8 10.5Z" fill="var(--color-surface-dark)"/>
        </svg>
        <svg class="c-theme-toggle__icon c-theme-toggle__icon--dark" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M17.5 11.5C16.5 12.2 15.3 12.6 14 12.6C10.5 12.6 7.6 9.7 7.6 6.2C7.6 4.9 8 3.7 8.7 2.7C4.9 3.5 2 6.8 2 10.8C2 15.3 5.7 19 10.2 19C14.2 19 17.5 16.1 18.3 12.3C18.1 12.1 17.8 11.8 17.5 11.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button></li>
    </ul>
  </div>

  {# Navigation Panel #}
  <nav class="c-nav" aria-label="Site Navigation">
    <ul class="c-nav__list">
      <li class="c-nav__item"><a href="/archives">Archives</a></li>
      <li class="c-nav__item"><a href="/projects">Projects</a></li>
      <li class="c-nav__item"><a href="/work">Work</a></li>
      <li class="c-nav__item"><a href="/blog">Blog</a></li>
      <li class="c-nav__item"><a href="/">Home</a></li>
    </ul>
  </nav>
</aside>

{# Bottom Drawers for toolbar options #}

{# Info Drawer #}
<div id="info-drawer" class="l-bottom-drawer" aria-hidden="true" inert>
  <div class="l-bottom-drawer__content">
    <button class="l-bottom-drawer__close" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <h2>About Me</h2>
    <p>I'm Jesse Gardner, a blogger, technologist, and humanist. I help people use technology to promote human flourishing. I've been at the intersection of design and engineering for nearly 20 years.</p>
  </div>
</div>

{# Text Settings Drawer #}
<div id="text-drawer" class="l-bottom-drawer" aria-hidden="true" inert>
  <div class="l-bottom-drawer__content">
    <button class="l-bottom-drawer__close" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="c-text-controls">
      {# Theme Mode - Segmented Control #}
      <fieldset class="c-text-controls__group c-theme-picker" role="radiogroup" aria-label="Color theme">
        <legend class="c-text-controls__label u-visually-hidden">Appearance</legend>
        <div class="c-theme-picker__options">
          <input type="radio" name="theme" id="theme-light" value="light" class="c-theme-picker__input">
          <label for="theme-light" class="c-theme-picker__option">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.05 3.05l1.06 1.06M11.89 11.89l1.06 1.06M3.05 12.95l1.06-1.06M11.89 4.11l1.06-1.06" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>Day</span>
          </label>
          <input type="radio" name="theme" id="theme-system" value="system" class="c-theme-picker__input" checked>
          <label for="theme-system" class="c-theme-picker__option">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 1.5A6.5 6.5 0 0 1 8 14.5Z" fill="currentColor"/>
              <path d="M8 5.5A2.5 2.5 0 0 1 8 10.5Z" fill="var(--color-surface)"/>
            </svg>
            <span>Auto</span>
          </label>
          <input type="radio" name="theme" id="theme-dark" value="dark" class="c-theme-picker__input">
          <label for="theme-dark" class="c-theme-picker__option">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M17.5 11.5C16.5 12.2 15.3 12.6 14 12.6C10.5 12.6 7.6 9.7 7.6 6.2C7.6 4.9 8 3.7 8.7 2.7C4.9 3.5 2 6.8 2 10.8C2 15.3 5.7 19 10.2 19C14.2 19 17.5 16.1 18.3 12.3C18.1 12.1 17.8 11.8 17.5 11.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Night</span>
          </label>
        </div>
      </fieldset>

      {# Font Size - Stepped Range Slider #}
      <div class="c-text-controls__group c-font-size-slider">
        <label for="font-size-range" class="c-text-controls__label u-visually-hidden">Text Size</label>
        <div class="c-font-size-slider__track">
          <button type="button" class="c-font-size-slider__icon c-font-size-slider__icon--small" aria-label="Decrease text size">A</button>
          <input type="range" id="font-size-range" name="font-size" min="1" max="5" step="1" value="3" class="c-font-size-slider__input" aria-valuetext="Medium">
          <button type="button" class="c-font-size-slider__icon c-font-size-slider__icon--large" aria-label="Increase text size">A</button>
        </div>
      </div>

      {# Line Height - 3 Button Options #}
      <div class="c-text-controls__group c-line-height-picker">
        <span class="c-text-controls__label u-visually-hidden">Line Spacing</span>
        <div class="c-line-height-picker__options">
          <button type="button" data-line-height="compact" class="c-line-height-picker__option" aria-label="Compact line spacing">
            <svg width="24" height="16" viewBox="0 0 24 16" fill="none" aria-hidden="true">
              <path d="M0 2h24M0 8h24M0 14h24" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </button>
          <button type="button" data-line-height="normal" class="c-line-height-picker__option is-active" aria-label="Normal line spacing">
            <svg width="24" height="20" viewBox="0 0 24 20" fill="none" aria-hidden="true">
              <path d="M0 2h24M0 10h24M0 18h24" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </button>
          <button type="button" data-line-height="relaxed" class="c-line-height-picker__option" aria-label="Relaxed line spacing">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M0 2h24M0 12h24M0 22h24" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

{# Search Drawer #}
<div id="search-drawer" class="l-bottom-drawer" aria-hidden="true" inert>
  <div class="l-bottom-drawer__content">
    <button class="l-bottom-drawer__close" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <h2>Search</h2>
    <form class="c-search-form" role="search">
      <input type="search" placeholder="Search posts..." aria-label="Search posts" class="c-search-form__input">
      <button type="submit" class="c-search-form__button">Search</button>
    </form>
    <div id="search-results" class="c-search-results"></div>
  </div>
</div>
