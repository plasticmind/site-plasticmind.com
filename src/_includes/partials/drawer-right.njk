{# Drawer Right - Author & Discovery #}
<aside id="right-drawer" class="l-drawer l-drawer--right" inert>

  {# Author Bio - no heading #}
  <div class="c-author-bio">
    <img src="/assets/i/jesse-profile.jpg" alt="Jesse Gardner" class="c-author-bio__photo">
    <p class="c-author-bio__text">Jesse has been bridging design and engineering for 20+ years. He leads the Design System and Accessibility teams for New York State, where he's been exploring how design systems can improve AI code output.</p>
  </div>

  {# Related Posts - only on post pages with tags #}
  {% if tags and tags.length %}
    {% set relatedPosts = collections.posts | relatedPosts(tags, page.url) | limit(4) %}
    {% if relatedPosts.length %}
    <nav class="c-related-posts">
      <h2 class="c-related-posts__heading">Related</h2>
      <ul class="c-related-posts__list">
        {% for post in relatedPosts %}
        <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
        {% endfor %}
      </ul>
    </nav>
    {% endif %}
  {% endif %}

  {# Tags from current post #}
  {% if tags and tags.length %}
  <nav class="c-drawer-tags" aria-label="Post topics">
    <h2 class="c-drawer-tags__heading">Topics</h2>
    <ul class="c-drawer-tags__list">
      {% for tag in tags %}
      <li class="c-drawer-tag"><a href="/tags/{{ tag | slugify }}/" rel="tag">#{{ tag }}</a></li>
      {% endfor %}
    </ul>
  </nav>
  {% endif %}

</aside>
